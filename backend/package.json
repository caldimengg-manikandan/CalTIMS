{
    "name": "timesheet-backend",
    "version": "1.0.0",
    "description": "CalTIMS - Time & HR Management System - Backend API",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "test": "jest --runInBand --forceExit",
        "test:unit": "jest tests/unit --runInBand --forceExit",
        "test:integration": "jest tests/integration --runInBand --forceExit",
        "test:coverage": "jest --coverage --runInBand --forceExit",
        "lint": "eslint src --ext .js",
        "lint:fix": "eslint src --ext .js --fix",
        "seed": "node seed.js",
        "db:migrate": "npx prisma migrate dev",
        "db:generate": "npx prisma generate",
        "db:studio": "npx prisma studio"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "axios": "^1.13.6",
        "bcryptjs": "^2.4.3",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "date-fns": "^4.1.0",
        "dotenv": "^16.4.5",
        "express": "^4.18.3",
        "express-rate-limit": "^7.5.1",
        "express-validator": "^7.1.0",
        "googleapis": "^171.4.0",
        "helmet": "^7.1.0",
        "ioredis": "^5.3.2",
        "joi": "^17.12.2",
        "json2csv": "^6.0.0-alpha.2",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "node-cron": "^4.2.1",
        "nodemailer": "^6.10.1",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "passport-microsoft": "^2.1.0",
        "pdfkit": "^0.15.0",
        "puppeteer": "^24.40.0",
        "socket.io": "^4.8.3",
        "uuid": "^9.0.1",
        "winston": "^3.13.0",
        "winston-daily-rotate-file": "^5.0.0",
        "xss-clean": "^0.1.4"
    },
    "devDependencies": {
        "eslint": "^8.57.0",
        "jest": "^29.7.0",
        "nodemon": "^3.1.0",
        "prisma": "^5.22.0",
        "supertest": "^7.0.0"
    },
    "jest": {
        "testEnvironment": "node",
        "testTimeout": 30000,
        "coverageDirectory": "coverage",
        "collectCoverageFrom": [
            "src/**/*.js",
            "!src/config/**"
        ]
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "author": "",
    "license": "ISC"
}
