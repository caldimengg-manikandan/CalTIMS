# ===========================
# Server
# ===========================
NODE_ENV=development
PORT=5000

# ===========================
# MongoDB
# ===========================
MONGODB_URI=mongodb://localhost:27017/timesheet_db

# ===========================
# JWT
# ===========================
JWT_ACCESS_SECRET=your_access_token_secret_change_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================
# Redis (optional — disable if not available)
# ===========================
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ===========================
# Email (Nodemailer / SendGrid)
# ===========================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=support@caldimengg.in
EMAIL_PASS=mQMcfPvYcegd
EMAIL_FROM=noreply@timesheet.app

# ===========================
# Client URL (for CORS)
# ===========================
CLIENT_URL=http://192.168.1.15:3000

# ===========================
# Cloudinary (for avatar uploads)
# ===========================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===========================
# Rate Limiting
# ===========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ===========================
# Bcrypt
# ===========================
BCRYPT_SALT_ROUNDS=12
